# ---- Storage ----
# Dev default: sqlite. Swap to postgresql://... for prod.
DATABASE_URL=sqlite:///./lore_forge.sqlite

# ---- Renderer paths (relative to backend/) ----
RENDERS_DIR=./renders
MUSIC_DIR=./assets/music
REMOTION_DIR=../remotion

# ---- APScheduler ----
# Opt-in weekly discovery cron. Leave false on dev machines to avoid
# racking up API calls on `uvicorn --reload`.
DISCOVERY_CRON_ENABLED=false
DISCOVERY_CRON_DAY=mon
DISCOVERY_CRON_HOUR=6

# ---- LLM keys ----
ANTHROPIC_API_KEY=
# Default is Opus 4.6 (best creative quality). Swap to claude-sonnet-4-6
# if you want to cut script-generation cost by ~3x.
CLAUDE_MODEL=claude-opus-4-6

OPENAI_API_KEY=
OPENAI_SCRIPT_MODEL=gpt-4o
OPENAI_META_MODEL=gpt-4o-mini

# Alibaba Dashscope hosts Qwen (chat) + Wanx (images) + CosyVoice (TTS).
DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-plus

# ---- Provider routing ----
# Script (creative, quality-sensitive):  claude | openai | qwen
SCRIPT_PROVIDER=claude
# Classify + per-platform meta (formulaic, high volume): claude | openai | qwen
META_PROVIDER=qwen
# Narration: openai | kokoro | dashscope | elevenlabs
TTS_PROVIDER=openai
# Images: wanx | dalle | imagen | replicate | sdxl_local | midjourney_manual
IMAGE_PROVIDER=wanx

# ---- Voice (optional upgrade) ----
ELEVENLABS_API_KEY=

# ---- Discovery ----
NYT_API_KEY=
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# ---- Affiliate ----
AMAZON_ASSOCIATE_TAG=
BOOKSHOP_AFFILIATE_ID=
# Optional — ISBN→ASIN lookup. If blank we fall back to OpenLibrary.
ISBNDB_API_KEY=

# ---- Publishing (Phase 2) — shorts-only targets ----
# TikTok, YouTube Shorts (Data API), Instagram Reels + Threads (Meta Graph).
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
META_APP_ID=
META_APP_SECRET=
