{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Lore Forge",
  "version": "0.1.0",
  "identifier": "com.loreforge.app",
  "build": {
    "beforeBuildCommand": "npm --prefix ../frontend run build",
    "beforeDevCommand": "npm --prefix ../frontend run dev",
    "devUrl": "http://localhost:3000",
    "frontendDist": "../frontend/out"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Lore Forge",
        "width": 1320,
        "height": 860,
        "minWidth": 1024,
        "minHeight": 640,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": ["binaries/sidecar"],
    "resources": [],
    "category": "Productivity",
    "shortDescription": "Automated content pipeline",
    "longDescription": "Lore Forge generates short-form video content end-to-end.",
    "macOS": {
      "minimumSystemVersion": "10.15",
      "entitlements": null,
      "exceptionDomain": null
    },
    "windows": {
      "allowDowngrades": true
    }
  },
  "plugins": {}
}
